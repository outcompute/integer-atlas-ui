# Absolute path used by BOTH the CLI and the UI so atlas.duckdb's absolute parquet
# paths resolve inside the notebook container. Must be writable by the CLI and exist
# on the host. Run the CLI with the same value, e.g.:
#   INTEGER_ATLAS_HOME="$HOME/integer-atlas" integer-atlas fetch --start 1 --end 1000000 --columns omega_big
INTEGER_ATLAS_HOME=/absolute/path/to/integer-atlas-home

# JupyterHub login (DummyAuthenticator): any username works; this user is admin.
JUPYTERHUB_ADMIN=admin
JUPYTERHUB_PASSWORD=atlas

# Optional: live-edit notebooks by bind-mounting them (absolute host path to ui/notebooks).
# Leave unset to use the notebooks baked into the image.
# NOTEBOOKS_DIR=/absolute/path/to/integer-atlas-ui/notebooks
